DATABASE_URL="postgresql://gamsi:gamsi@localhost:54329/gamsi?schema=public"
# Production must use a 32+ char random secret, not this placeholder.
AUTH_SECRET="replace-with-a-long-random-secret"
# Local HTTP Docker runs should keep this false. Production HTTPS must use true.
AUTH_COOKIE_SECURE="false"
# Production must use the deployed https origin.
APP_BASE_URL="http://localhost:3000"

# Optional SMTP settings for invitation emails
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="워크가드 <no-reply@workguard.local>"

# Optional web push settings
WEB_PUSH_SUBJECT="mailto:admin@example.com"
WEB_PUSH_VAPID_PUBLIC_KEY=""
WEB_PUSH_VAPID_PRIVATE_KEY=""

# Optional attachment storage. Use local for development; use s3 for production object storage.
ATTACHMENT_STORAGE_DRIVER="local"
ATTACHMENT_UPLOAD_ROOT=""
S3_ENDPOINT=""
S3_REGION="ap-northeast-2"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"
S3_KEY_PREFIX="workguard"
