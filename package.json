{
  "name": "workguard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src tests scripts prisma/seed.mjs next.config.mjs eslint.config.mjs playwright.config.mjs",
    "typecheck": "tsc --noEmit",
    "ci:check": "npm run typecheck && npm run lint && npm run build",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "qa:regression": "node scripts/qa-regression.mjs",
    "qa:e2e": "playwright test",
    "ops:deploy-rehearsal": "node scripts/deploy-rehearsal.mjs",
    "ops:deploy-vps": "node scripts/deploy-vps.mjs",
    "push:vapid": "node scripts/generate-vapid-keys.mjs",
    "ops:bootstrap-admin": "node scripts/bootstrap-admin.mjs",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:backup": "node scripts/backup-db.mjs",
    "db:restore": "node scripts/restore-db.mjs",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@types/web-push": "^3.6.4",
    "lucide-react": "0.468.0",
    "next": "^16.2.4",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "22.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "prisma": "5.22.0",
    "typescript": "5.7.2"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
