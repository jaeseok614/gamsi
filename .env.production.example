# Required in production.
DATABASE_URL="postgresql://workguard:replace-me@db.example.com:5432/workguard?schema=public"
AUTH_SECRET="replace-with-32-plus-random-characters"
AUTH_COOKIE_SECURE="true"
APP_BASE_URL="https://workguard.example.com"

# Optional but recommended for invitations, password reset, and notification delivery.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_FROM="워크가드 <no-reply@example.com>"

# Optional but recommended for browser push notifications.
# Generate values with: npm run push:vapid
WEB_PUSH_SUBJECT="mailto:ops@example.com"
WEB_PUSH_VAPID_PUBLIC_KEY=""
WEB_PUSH_VAPID_PRIVATE_KEY=""

# Recommended for production attachments and groupware documents.
ATTACHMENT_STORAGE_DRIVER="s3"
S3_ENDPOINT="https://s3.ap-northeast-2.amazonaws.com"
S3_REGION="ap-northeast-2"
S3_BUCKET="workguard-attachments"
S3_ACCESS_KEY_ID="replace-me"
S3_SECRET_ACCESS_KEY="replace-me"
S3_FORCE_PATH_STYLE="false"
S3_KEY_PREFIX="prod"

# Deployment notes:
# - Do not commit real values.
# - APP_BASE_URL must be the public HTTPS origin.
# - AUTH_COOKIE_SECURE must stay true behind HTTPS.
# - AUTH_SECRET must not contain "change-before-production".
